# AndroidClaw 配置 —— 复制为 ~/.aclawrc 后填值,运行前 `source ~/.aclawrc`
# (~/.aclawrc 权限设 600,不进仓库)

# ── 大脑选择 ────────────────────────────────
# qwen / claude / gemini;留空 = 按下面哪个 key 存在自动选(优先级 qwen > gemini > claude)
export ACLAW_BRAIN=qwen

# ── API Key(填你要用的那个)──────────────────
export DASHSCOPE_API_KEY=            # Qwen-VL(阿里 DashScope,国内直连免代理)
export ANTHROPIC_API_KEY=            # Claude(需代理)
export GEMINI_API_KEY=               # Gemini(需代理,免费额度有限)

# ── 模型(可选,有默认值)─────────────────────
export ACLAW_QWEN_MODEL=qwen3.7-plus
# export ACLAW_MODEL=claude-sonnet-4-6
# export ACLAW_GEMINI_MODEL=gemini-2.5-flash
# export DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── 设备 ────────────────────────────────────
export ACLAW_USE_EVDEV=1             # 1=evdev 底层触摸注入(更真);0=input tap

# ── 运行时行为 ──────────────────────────────
export ACLAW_STAY_AWAKE=1            # 1=跑任务时保持亮屏(防息屏中断);0=关
export ACLAW_APPROVAL=on-request     # unless-trusted | on-request | never
# export ACLAW_AUTO_APPROVE=          # session | approve(后台无人值守时用;支付慎用)
# export ACLAW_MAX_STEPS=30
# export ACLAW_STEP_TIMEOUT_MS=30000
# export ACLAW_STUCK_THRESHOLD=3

# ── 感知 / OCR(可选)────────────────────────
# export ACLAW_OCR=1                 # 0=关 OCR 兜底
# export ACLAW_TESS_LANG=chi_sim
# export ACLAW_TESS_PSM=12

# ── 人格(可选)─────────────────────────────
# export ACLAW_PERSONA_FILE=prompts/persona.md   # agent 撰写消息时的身份/口吻
# export ACLAW_PERSONA=                            # 或直接内联人格文本

# ── 路径(可选,有默认值)─────────────────────
# export ACLAW_ROOT=~/aclaw
# export ACLAW_ROLLOUT=~/aclaw/rollout
